romPort\&quot;:\&quot;OUT\&quot;,\&quot;toPort\&quot;:\&quot;in1\&quot;,\&quot;key\&quot;:-22,\&quot;points\&quot;:[250,-20,260,-20,260,-20,280,-20,280,-240,-270,-240,-270,-20,-250,-20,-250,-20,-240,-20],\&quot;routing\&quot;:\&quot;Orthogonal\&quot;},{\&quot;from\&quot;:10,\&quot;to\&quot;:4,\&quot;fromPort\&quot;:\&quot;OUT\&quot;,\&quot;toPort\&quot;:\&quot;in0\&quot;,\&quot;key\&quot;:-23,\&quot;points\&quot;:[250,120,260,120,300,120,300,-260,-290,-260,-290,0,-250,0,-240,0],\&quot;routing\&quot;:\&quot;Orthogonal\&quot;}]},\&quot;properties\&quot;:{}},{\&quot;type\&quot;:1,\&quot;id\&quot;:\&quot;c4503619-9955-4e4e-a4bf-cd2043487b8a\&quot;,\&quot;name\&quot;:\&quot;incr4\&quot;,\&quot;text\&quot;:\&quot;/*\\nMicrochip CLB Synthesizer - new Verilog file\\n\\nImplement your Verilog module in this file and use it elsewhere in your CLB design.\\n\\n// Example 1: combinatorial AND implementation:\\nmodule incr4 (a, b, q);\\n    input a, b;\\n    output q;\\n    assign q \u003d a \u0026 b;\\nendmodule\\n\\n// Example 2: clocked one-bit counter that toggles only when enabled\\nmodule incr4 (CLK, enable, q);\\n    input CLK;\\n    input enable;\\n    output reg q;\\n    always @(posedge CLK) begin\\n        if (enable) begin\\n            q \u003c\u003d !q;\\n        end\\n    end\\nendmodule\\n\\nTips for using Verilog in the CLB Synthesizer:\\n  - SystemVerilog and VHDL are not supported; use Verilog-2005 only.\\n  - The CLB has a single global clock which is the \u0027CLK\u0027 port in all Verilog modules.\\n  - It is not possible to use \u0027always @\u0027 constructs other than \u0027always @(posedge CLK)\u0027.\\n*/\\n\\nmodule incr4(in3,in2,in1,in0,out3,out2,out1,out0);\\n    input in3, in2, in1, in0;\\n    output out3, out2, out1, out0;\\n    wire [3:0] inbus;\\n    wire [3:0] outbus;\\n    assign inbus \u003d {in3, in2, in1, in0};\\n    assign outbus \u003d inbus + 1;\\n    assign out3 \u003d outbus[3];\\n    assign out2 \u003d outbus[2];\\n    assign out1 \u003d outbus[1];\\n    assign out0 \u003d outbus[0];\\nendmodule\&quot;},{\&quot;type\&quot;:1,\&quot;id\&quot;:\&quot;f64df0bc-7140-4c06-85eb-35bf99bcb8b2\&quot;,\&quot;name\&quot;:\&quot;incr3\&quot;,\&quot;text\&quot;:\&quot;/*\\nMicrochip CLB Synthesizer - new Verilog file\\n\\nImplement your Verilog module in this file and use it elsewhere in your CLB design.\\n\\n// Example 1: combinatorial AND implementation:\\nmodule incr3 (a, b, q);\\n    input a, b;\\n    output q;\\n    assign q \u003d a \u0026 b;\\nendmodule\\n\\n// Example 2: clocked one-bit counter that toggles only when enabled\\nmodule incr3 (CLK, enable, q);\\n    input CLK;\\n    input enable;\\n    output reg q;\\n    always @(posedge CLK) begin\\n        if (enable) begin\\n            q \u003c\u003d !q;\\n        end\\n    end\\nendmodule\\n\\nTips for using Verilog in the CLB Synthesizer:\\n  - SystemVerilog and VHDL are not supported; use Verilog-2005 only.\\n  - The CLB has a single global clock which is the \u0027CLK\u0027 port in all Verilog modules.\\n  - It is not possible to use \u0027always @\u0027 constructs other than \u0027always @(posedge CLK)\u0027.\\n*/\\n\\nmodule incr3(in2,in1,in0,out2,out1,out0);\\n    input  in2, in1, in0;\\n    output out2, out1, out0;\\n    wire [2:0] inbus;\\n    wire [2:0] outbus;\\n    assign inbus \u003d { in2, in1, in0};\\n    assign outbus \u003d inbus + 1;\\n    assign out2 \u003d outbus[2];\\n    assign out1 \u003d outbus[1];\\n    assign out0 \u003d outbus[0];\\nendmodule\&quot;},{\&quot;type\&quot;:0,\&quot;id\&quot;:\&quot;df815d05-a073-4052-9f8c-d23c03a1981d\&quot;,\&quot;name\&quot;:\&quot;sipo_buff4\&quot;,\&quot;data\&quot;:{\&quot;class\&quot;:\&quot;GraphLinksModel\&quot;,\&quot;linkKeyProperty\&quot;:\&quot;key\&quot;,\&quot;linkFromPortIdProperty\&quot;:\&quot;fromPort\&quot;,\&quot;linkToPortIdProperty\&quot;:\&quot;toPort\&quot;,\&quot;nodeDataArray\&quot;:[{\&quot;category\&quot;:\&quot;moduleoutputport\&quot;,\&quot;loc\&quot;:\&quot;380 