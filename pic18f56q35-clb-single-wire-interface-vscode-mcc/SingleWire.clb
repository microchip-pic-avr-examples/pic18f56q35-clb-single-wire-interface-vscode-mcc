ting":"Orthogonal"},{"from":9,"to":4,"fromPort":"OUT","toPort":"in1","key":-22,"points":[250,-20,260,-20,260,-20,280,-20,280,-240,-270,-240,-270,-20,-250,-20,-250,-20,-240,-20],"routing":"Orthogonal"},{"from":10,"to":4,"fromPort":"OUT","toPort":"in0","key":-23,"points":[250,120,260,120,300,120,300,-260,-290,-260,-290,0,-250,0,-240,0],"routing":"Orthogonal"}]},"properties":{}},{"type":1,"id":"c4503619-9955-4e4e-a4bf-cd2043487b8a","name":"incr4","text":"/*\nMicrochip CLB Synthesizer - new Verilog file\n\nImplement your Verilog module in this file and use it elsewhere in your CLB design.\n\n// Example 1: combinatorial AND implementation:\nmodule incr4 (a, b, q);\n    input a, b;\n    output q;\n    assign q = a & b;\nendmodule\n\n// Example 2: clocked one-bit counter that toggles only when enabled\nmodule incr4 (CLK, enable, q);\n    input CLK;\n    input enable;\n    output reg q;\n    always @(posedge CLK) begin\n        if (enable) begin\n            q <= !q;\n        end\n    end\nendmodule\n\nTips for using Verilog in the CLB Synthesizer:\n  - SystemVerilog and VHDL are not supported; use Verilog-2005 only.\n  - The CLB has a single global clock which is the 'CLK' port in all Verilog modules.\n  - It is not possible to use 'always @' constructs other than 'always @(posedge CLK)'.\n*/\n\nmodule incr4(in3,in2,in1,in0,out3,out2,out1,out0);\n    input in3, in2, in1, in0;\n    output out3, out2, out1, out0;\n    wire [3:0] inbus;\n    wire [3:0] outbus;\n    assign inbus = {in3, in2, in1, in0};\n    assign outbus = inbus + 1;\n    assign out3 = outbus[3];\n    assign out2 = outbus[2];\n    assign out1 = outbus[1];\n    assign out0 = outbus[0];\nendmodule"},{"type":1,"id":"f64df0bc-7140-4c06-85eb-35bf99bcb8b2","name":"incr3","text":"/*\nMicrochip CLB Synthesizer - new Verilog file\n\nImplement your Verilog module in this file and use it elsewhere in your CLB design.\n\n// Example 1: combinatorial AND implementation:\nmodule incr3 (a, b, q);\n    input a, b;\n    output q;\n    assign q = a & b;\nendmodule\n\n// Example 2: clocked one-bit counter that toggles only when enabled\nmodule incr3 (CLK, enable, q);\n    input CLK;\n    input enable;\n    output reg q;\n    always @(posedge CLK) begin\n        if (enable) begin\n            q <= !q;\n        end\n    end\nendmodule\n\nTips for using Verilog in the CLB Synthesizer:\n  - SystemVerilog and VHDL are not supported; use Verilog-2005 only.\n  - The CLB has a single global clock which is the 'CLK' port in all Verilog modules.\n  - It is not possible to use 'always @' constructs other than 'always @(posedge CLK)'.\n*/\n\nmodule incr3(in2,in1,in0,out2,out1,out0);\n    input  in2, in1, in0;\n    output out2, out1, out0;\n    wire [2:0] inbus;\n    wire [2:0] outbus;\n    assign inbus = { in2, in1, in0};\n    assign outbus = inbus + 1;\n    assign out2 = outbus[2];\n    assign out1 = outbus[1];\n    assign out0 = outbus[0];\nendmodule"},{"type":0,"id":"df815d05-a073-4052-9f8c-d23c03a1981d","name":"sipo_buff4","data":{"class":"GraphLinksModel","linkKeyProperty":"key","linkFromPortIdProperty":"fromPort","linkToPortIdProperty":"toPort","nodeDataArray":[{"category":"moduleoutputport","loc":"380 1850","key":4,"angle":0,"flipX":false,"portname":"OUT0","size":"130 20","settings":{}},{"category":"moduleoutputport","loc":"390 1750","key":5,"angle":0,"flipX":false,"portname":"OUT1","size":"130 20","settings":{}},{"category":"moduleoutputport","loc":"390 1650","key":6,"angle":0,"flipX":false,"portname":"OUT2","size":"130 20","settings":{}},{"category":"moduleoutputport","loc":"390 1560","key":7,"angle":0,"flipX":false,"portname":"OUT3","size":"130 20","settings":{}},{"category":"moduleoutputport","loc":"410 1280","key":8,"angle":0,"flipX":false,"portname":"OUT4","size":"130 20","settings":{}},{"category":"moduleoutputport","loc":"410 1180","key":9,"angle":0,"flipX":false,"portname":"OUT5","size":"130 20","settings":{}},{"category":"moduleoutputport","loc":"410 1080","key":10,"angle":0,"flipX":fa